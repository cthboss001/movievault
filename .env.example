# MovieVault Environment Variables
# Copy this file to .env and fill in the values.

# ── Required: PostgreSQL Database ────────────────────────────────────────────
# Replace with your actual PostgreSQL connection string.
# Options:
#   - Local:   postgresql://postgres:password@localhost:5432/movievault
#   - Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/movievault?sslmode=require
#   - Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/movievault?schema=public"

# ── Required in production: Sync endpoint protection ─────────────────────────
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave commented out or empty in local development (sync works without auth locally).
# SYNC_SECRET="replace-with-a-long-random-secret"
